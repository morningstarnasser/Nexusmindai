{
  "name": "nexusmind",
  "version": "0.1.0",
  "description": "NexusMind — The Ultimate Autonomous AI Agent Platform. 1000x beyond OpenClaw.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "dashboard": "cd dashboard && npm run dev",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "db:migrate": "tsx src/storage/migrations/run.ts",
    "cli": "tsx cli/src/index.ts"
  },
  "keywords": ["ai", "agent", "autonomous", "chatbot", "llm", "openai", "anthropic", "telegram", "discord", "whatsapp"],
  "author": "Morningstar",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "node-cron": "^3.0.3",
    "sqlite3": "^5.1.7",
    "discord.js": "^14.16.0",
    "@slack/bolt": "^4.1.0",
    "@slack/web-api": "^7.5.0",
    "telegraf": "^4.16.0",
    "whatsapp-web.js": "^1.26.0",
    "twilio": "^5.3.0",
    "botbuilder": "^4.23.0",
    "nodemailer": "^6.9.0",
    "imap-simple": "^5.1.0",
    "matrix-js-sdk": "^34.0.0",
    "@aws-sdk/client-sns": "^3.600.0",
    "irc": "^0.5.2"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/imap-simple": "^4.2.0",
    "@types/irc": "^0.3.0",
    "vitest": "^2.1.0",
    "@playwright/test": "^1.48.0",
    "eslint": "^9.12.0",
    "prettier": "^3.3.0"
  }
}
