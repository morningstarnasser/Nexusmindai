# NexusMind Configuration
NODE_ENV=development
PORT=3000
API_PORT=3001
WS_PORT=3002

# Encryption
ENCRYPTION_KEY=change-me-to-a-random-32-char-string

# ============================================================
# Database (Neon PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host/dbname?sslmode=require
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGDATABASE=
PGPASSWORD=

# ============================================================
# AI Model API Keys (add the ones you use)
# ============================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=
NVIDIA_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=

# ============================================================
# Messaging Platform Credentials
# ============================================================

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=

# Discord
DISCORD_BOT_TOKEN=

# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Signal
SIGNAL_CLI_PATH=

# WhatsApp (uses QR code auth, no key needed)

# Email (IMAP/SMTP)
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USER=
EMAIL_PASS=

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================================
# Voice / TTS
# ============================================================
ELEVENLABS_API_KEY=

# ============================================================
# Smart Home
# ============================================================
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# ============================================================
# Dashboard
# ============================================================
DASHBOARD_SECRET=change-me-to-a-random-string
DASHBOARD_URL=http://localhost:3000
